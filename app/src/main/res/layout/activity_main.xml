<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F7F5">

    <!-- ── ШАПКА ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="14dp"
        android:paddingBottom="12dp"
        android:elevation="4dp">

        <!-- строка: адрес + профиль + корзина -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:text="📍 Доставка по адресу"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="10sp"
                    android:textColor="#888888"/>

                <TextView
                    android:id="@+id/delivery_address_text"
                    android:text="Укажите адрес доставки"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textColor="#1A1A1A"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end"/>
            </LinearLayout>

            <!-- Профиль -->
            <FrameLayout
                android:id="@+id/profile_btn"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/cart_bg"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginEnd="8dp">
                <TextView
                    android:text="👤"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:textSize="18sp"/>
            </FrameLayout>

            <!-- Корзина + бейдж -->
            <FrameLayout
                android:id="@+id/cart_fab"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/cart_bg"
                android:clickable="true"
                android:focusable="true">
                <TextView
                    android:text="🛒"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:textSize="18sp"/>
                <LinearLayout
                    android:id="@+id/cart_badge_layout"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_gravity="top|end"
                    android:background="@drawable/badge_bg"
                    android:gravity="center"
                    android:visibility="gone">
                    <TextView
                        android:id="@+id/cart_count_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="9sp"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"/>
                </LinearLayout>
            </FrameLayout>
        </LinearLayout>

        <!-- Поиск (декоративный) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:background="@drawable/search_bg"
            android:gravity="center_vertical"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:layout_marginBottom="10dp">
            <TextView
                android:text="🔍"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="14sp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Поиск свежих продуктов..."
                android:textSize="13sp"
                android:textColor="#AAAAAA"/>
        </LinearLayout>

        <!-- Чипы категорий -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none">
            <LinearLayout
                android:id="@+id/chip_container"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"/>
        </HorizontalScrollView>
    </LinearLayout>

    <!-- ── КОНТЕНТ (скролл) ── -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="16dp"
            android:paddingBottom="28dp">

            <!-- Баннер -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="110dp"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#2D7A3A">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp">
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:text="🎉 Бесплатная доставка!"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="16sp"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold"/>
                        <TextView
                            android:text="При первом заказе от 2000 ₽"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="12sp"
                            android:textColor="#CCFFCC"
                            android:layout_marginTop="4dp"/>
                        <TextView
                            android:text="Промокод: FRESH30"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="11sp"
                            android:textColor="#FFDD57"
                            android:textStyle="bold"
                            android:layout_marginTop="6dp"/>
                    </LinearLayout>
                    <TextView
                        android:text="🛵"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="44sp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Заголовок раздела -->
            <TextView
                android:text="Свежее сегодня 🌿"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="18sp"
                android:textColor="#1A1A1A"
                android:textStyle="bold"
                android:layout_marginBottom="14dp"/>

            <!-- Сетка товаров -->
            <LinearLayout
                android:id="@+id/product_grid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
